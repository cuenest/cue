# Default sync hub baked into every PRODUCTION web build (the web deploy, and the
# desktop + mobile shells that bundle web/dist). A bare host is treated as wss://.
#
# Precedence: an actual VITE_DEFAULT_HUB in the environment always wins over this
# file — that's how the Render blueprint injects the real hub host, and how you
# can override per build. This value is only the fallback when nothing is set.
# Dev (`vite`, mode=development) does not read this file, so it still falls back
# to ws://localhost:4444.
VITE_DEFAULT_HUB=wss://cue-hub.onrender.com
