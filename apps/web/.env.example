# Default sync hub the web app points at, baked in at build time.
# Full ws(s):// URL or a bare host (a bare host is treated as wss://).
# Leave unset for local dev — it falls back to ws://localhost:4444.
# Per-space overrides in Settings always win; this is only the default.
VITE_DEFAULT_HUB=wss://cue-hub.onrender.com
