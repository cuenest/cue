# Baked into the extension build. Leave unset for local dev (falls back to the
# dev servers). Set both when building the extension you publish to a store.
#
# Default sync hub (full ws(s):// URL or a bare host, treated as wss://). The
# hub in a pasted link code always wins; this is only the fallback.
VITE_DEFAULT_HUB=wss://cue-hub.onrender.com
# The full Cue web app the popup's "open cue →" link opens.
VITE_APP_URL=https://cue-web.onrender.com
